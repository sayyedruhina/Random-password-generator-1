def calculate_bmi(weight, height):
    # BMI Formula: weight (kg) / height (m)^2
    bmi = weight / (height ** 2)
    return round(bmi, 2)

def get_bmi_category(bmi):
    # WHO standard categories
    if bmi < 18.5:
        return "Underweight"
    elif 18.5 <= bmi < 24.9:
        return "Normal weight"
    elif 25 <= bmi < 29.9:
        return "Overweight"
    else:
        return "Obese"

